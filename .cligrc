[changelog]
# Header for the changelog file
header = """
# Changelog\n
All notable changes to this project will be documented in this file.\n
"""
# Template for the changelog
body = """
{% for group, commits in commits | group_by(attribute="group") %}
### {{ group | upper_first }}\n
{% for commit in commits %}
- {% if commit.scope %**{{ commit.scope }}:** {% endif %}{{ commit.message | upper_first }}\n
{% endfor %}
{% endfor %}
"""
# Footer for the changelog
footer = """
<!-- generated by git-cliff -->
"""
# Remove the header from the output (we use our own)
trim = true

[conventionalcommits]
# Parse conventional commit format
default_alert_scope = ""

[git]
# Parse commit messages with these patterns
parse_ignore_commits = [
    "^docs: \\[skip changelog\\]",
    "^chore: \\[skip changelog\\]",
]

# Tag configuration
tag_resolve_pattern = "v({version})"

# Protects these branches from being included in the changelog
protect_protected_tags = false

# Include all commits, not just from last tag
unprotect_protected_tags = false

# Treat all commits as part of the changelog
top_level_trailer = false

[workspace]
# Workspace configuration (empty for this project)

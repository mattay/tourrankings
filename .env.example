# Runtime
NODE_ENV=development

# Server
PORT=8080
DATA_DIR=./data/csv/
DATA_AUTO_REFRESH=TRUE
DATA_AUTO_REFRESH_INTERVAL=3600000

# Security
CORS_ORIGIN=https://tour-rankings.com

# File Watching
# Enable watching CSV files for changes (near real-time updates when scraper runs)
DATA_WATCH_FILES=TRUE
# Debounce duration in milliseconds (default: 60000 = 1 minute)
# Prevents multiple refreshes when scraper writes after each stage
DATA_WATCH_DEBOUNCE_MS=60000

# Webscraping
HTML_CACHE_ENABLED=true
HTML_CACHE_DIR=./data/html
HTML_CACHE_BEAUTIFY=false
# Enabled by default (recommended)
HTML_CACHE_REMOVE_SCRIPTS=true
HTML_CACHE_REMOVE_STYLES=false    # Keep CSS
HTML_CACHE_REMOVE_COMMENTS=false  # Keep comments

# HTML Cache TTL Configuration (values in minutes)
HTML_CACHE_TTL_LIVE=30         # Live data: start list (before race), stages (during race)
HTML_CACHE_TTL_FIXED=43200     # Fixed data: 30 days in minutes (30 * 24 * 60)
RESULTS_POLL_START_OFFSET=1    # Days before stage date to start polling
STAGE_GRACE_PERIOD=1           # Days after race end to keep short TTL

# Suppress expected errors for future races (missing staff, riders, bibs, etc.)
# Set to "true" to silence these errors globally
SUPPRESS_FUTURE_RACE_ERRORS=false

# Races
# SEASON=2025              # Specific year to scrape (default: current year)
# START_SEASON=2024        # Start year for range (runs from START_SEASON to current year)

# CLI Arguments:
# bun scrape                    # Scrape current year only
# bun scrape --season 2024     # Scrape from 2024 to current year

# Races
SEASON=2025

GOOGLE_SHEETS_ID="#SECRET"
GOOGLE_SERVICE_ACCOUNT_KEY_FILE="#SECRET_google-service-account-key.json"

# Testing
TEST_DATA_DIR=./data/temp/test/

# Memory Diagnostics
# Enable to log memory usage during scrape (useful for profiling)
# DEBUG_MEMORY=true

# File Logging
FILE_LOGGING_ENABLED=true
LOG_DIR=./data/logs  # Override to /tourRanking/data/logs in container deployments

# Access log (pages + unknowns)
LOG_ACCESS_ROTATION_DAYS=90
LOG_ACCESS_ROTATION_SIZE_MB=50
# LOG_ACCESS_RETENTION_DAYS=  # null = keep forever

# API log (API endpoints)
LOG_API_ROTATION_DAYS=90
LOG_API_ROTATION_SIZE_MB=50
# LOG_API_RETENTION_DAYS=  # null = keep forever

# Health log (health checks)
LOG_HEALTH_ROTATION_DAYS=7
LOG_HEALTH_ROTATION_SIZE_MB=10
# LOG_HEALTH_RETENTION_DAYS=  # null = keep forever

# Static log (assets)
LOG_STATIC_ROTATION_DAYS=30
LOG_STATIC_ROTATION_SIZE_MB=50
# LOG_STATIC_RETENTION_DAYS=  # null = keep forever

# Process metadata (injected by CI/CD)
BRANCH_NAME=
COMMIT_SHA=

# Runtime
NODE_ENV=development

# Server
PORT=8080
DATA_DIR=./data/csv/
DATA_AUTO_REFRESH=TRUE
DATA_AUTO_REFRESH_INTERVAL=3600000

# File Watching
# Enable watching CSV files for changes (near real-time updates when scraper runs)
DATA_WATCH_FILES=TRUE
# Debounce duration in milliseconds (default: 60000 = 1 minute)
# Prevents multiple refreshes when scraper writes after each stage
DATA_WATCH_DEBOUNCE_MS=60000

# Webscraping
HTML_CACHE_ENABLED=true
HTML_CACHE_DIR=./data/html
HTML_CACHE_BEAUTIFY=false
# Enabled by default (recommended)
HTML_CACHE_REMOVE_SCRIPTS=true
HTML_CACHE_REMOVE_STYLES=false    # Keep CSS
HTML_CACHE_REMOVE_COMMENTS=false  # Keep comments

# Races
# SEASON=2025              # Specific year to scrape (default: current year)
# START_SEASON=2024        # Start year for range (runs from START_SEASON to current year)

# CLI Arguments:
# bun scrape                    # Scrape current year only
# bun scrape --season 2024     # Scrape from 2024 to current year

# Races
SEASON=2025

GOOGLE_SHEETS_ID="#SECRET"
GOOGLE_SERVICE_ACCOUNT_KEY_FILE="#SECRET_google-service-account-key.json"

# Testing
TEST_DATA_DIR=./data/temp/test/

# Memory Diagnostics
# Enable to log memory usage during scrape (useful for profiling)
# DEBUG_MEMORY=true

{
  "name": "tourrankings",
  "version": "1.0.0",
  "main": "src/server/index.js",
  "scripts": {
    "scrape": "bun src/scrappers/scrape_proCyclingStats.js",
    "start": "bun src/server/index.js",
    "build": "bun scripts/build.js",
    "local": "docker compose -f docker-compose.local.yml up",
    "local:down": "docker compose -f docker-compose.local.yml down",
    "local:build": "docker compose -f docker-compose.local.yml up --build",
    "local:clean": "docker compose -f docker-compose.local.yml build --no-cache",
    "local:scrape": "docker compose -f docker-compose.local.yml exec app sh -c '. /chrome-path.sh && bun scrape'",
    "local:shell": "docker compose -f docker-compose.local.yml exec app sh",
    "test:build": "docker compose -f docker-compose.test-build.yml up --build",
    "test:clean": "docker compose -f docker-compose.test-build.yml build --no-cache && docker compose -f docker-compose.test-build.yml up",
    "test:down": "docker compose -f docker-compose.test-build.yml down",
    "test:scrape": "docker compose -f docker-compose.test-build.yml exec app sh -c '. /chrome-path.sh && bun scrape'",
    "deploy:dev": "fly deploy --config fly.dev.toml",
    "deploy:prod": "fly deploy --config fly.prod.toml",
    "deploy:dev:logs": "fly logs --config fly.dev.toml",
    "deploy:prod:logs": "fly logs --config fly.prod.toml",
    "audit": "yarn audit",
    "lint": "eslint src/**/*.js",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "keywords": [
    "cycling"
  ],
  "author": "Matthew Anderson",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "googleapis": "^150.0.1",
    "helmet": "^8.1.0",
    "html-minifier-next": "^5.0.6",
    "js-beautify": "^1.15.4",
    "jsdom": "^26.1.0",
    "puppeteer-core": "^24.30.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.56.1",
    "@types/d3": "^7.4.3",
    "@types/express": "^5.0.6",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "yarn": "^1.22.22"
  },
  "engines": {
    "bun": ">=1.2.10",
    "node": ">=20.0.0"
  }
}
